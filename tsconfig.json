{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"isolatedModules": true,
		"lib": ["ESNext"],
		"types": [
			"@cloudflare/workers-types",
			"@types/bun"
		]
	},
	"include": ["src"]
}
